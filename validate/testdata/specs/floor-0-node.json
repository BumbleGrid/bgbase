{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bumblegrid.tech/schemas/bgspec/v0.1/floor-0-node.json",
  "title": "BGSpec Floor 0 Node",
  "description": "Defines a single node at Floor 0 (Physical / Logical layer) of a Bumble Grid Specification document. Floor 0 nodes are produced exclusively by automated extraction from infrastructure-as-code sources (e.g. Kubernetes, Terraform). Human authoring is restricted to 'meta' overrides and to rendering overrides in the root document 'styleMap' (never written by extractors).",

  "type": "object",
  "required": ["data"],
  "additionalProperties": false,

  "properties": {
    "data": {
      "type": "object",
      "description": "Cytoscape-compatible data envelope. All BGSpec fields live here.",
      "required": ["id", "label", "floor", "bgKind", "infraProvider"],
      "additionalProperties": false,

      "properties": {

        "id": {
          "type": "string",
          "description": "Globally unique node identifier within this BGSpec document. Recommended convention: '<provider>-<namespace>-<name>' e.g. 'k8s-payments-api-deployment'.",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9\\-\\.]*[a-z0-9]$"
        },

        "label": {
          "type": "string",
          "description": "Human-readable display name for this node.",
          "minLength": 1
        },

        "floor": {
          "type": "integer",
          "description": "Floor number. Always 0 for Floor 0 nodes.",
          "const": 0
        },

        "bgKind": {
          "type": "string",
          "description": "Bumble Grid's own node taxonomy. Defines the logical role of the node across all floors, provider-agnostic. The closed vocabulary below is for Floor 0; future floors will extend this enum.",
          "enum": [
            "Workload",
            "Database",
            "Cache",
            "MessageBroker",
            "Storage",
            "Gateway",
            "LoadBalancer",
            "ExternalService",
            "ConfigSource",
            "SecretSource",
            "ServiceDiscovery",
            "NetworkPolicy",
            "JobRunner",
            "Namespace",
            "Cluster"
          ]
        },

        "infraProvider": {
          "type": "string",
          "description": "Identifies the infrastructure-as-code source that produced this node. Determines which provider-specific block ('k8s', 'terraform', etc.) is present and valid.",
          "enum": [
            "kubernetes",
            "terraform",
            "pulumi",
            "cloudformation",
            "manual"
          ]
        },

        "k8s": {
          "type": "object",
          "description": "Kubernetes-specific fields. Required when infraProvider is 'kubernetes'. Must be absent or null for other providers.",
          "required": ["kind", "name"],
          "additionalProperties": false,
          "properties": {

            "kind": {
              "type": "string",
              "description": "The raw Kubernetes resource kind. Drives validation of bgKind compatibility (see bgKind-to-k8sKind mapping in BGSpec docs).",
              "enum": [
                "Deployment",
                "StatefulSet",
                "DaemonSet",
                "ReplicaSet",
                "Pod",
                "Job",
                "CronJob",
                "Service",
                "Ingress",
                "IngressClass",
                "ConfigMap",
                "Secret",
                "PersistentVolumeClaim",
                "PersistentVolume",
                "StorageClass",
                "HorizontalPodAutoscaler",
                "VerticalPodAutoscaler",
                "NetworkPolicy",
                "ServiceAccount",
                "ClusterRole",
                "ClusterRoleBinding",
                "Role",
                "RoleBinding",
                "Namespace",
                "ResourceQuota",
                "LimitRange",
                "EndpointSlice",
                "CustomResourceDefinition"
              ]
            },

            "name": {
              "type": "string",
              "description": "Kubernetes resource name (metadata.name).",
              "minLength": 1
            },

            "namespace": {
              "type": ["string", "null"],
              "description": "Kubernetes namespace. Null for cluster-scoped resources (e.g. Namespace, ClusterRole, PersistentVolume)."
            },

            "apiVersion": {
              "type": "string",
              "description": "Kubernetes API version (e.g. 'apps/v1', 'v1', 'networking.k8s.io/v1'). Useful for CRDs and non-core resources.",
              "examples": ["apps/v1", "v1", "batch/v1", "networking.k8s.io/v1"]
            },

            "uid": {
              "type": "string",
              "description": "Kubernetes resource UID (metadata.uid). Useful for stable cross-referencing if the name is reused across deploys.",
              "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
            },

            "labels": {
              "type": "object",
              "description": "Key-value labels from metadata.labels. Preserved for filtering and grouping in visualizers.",
              "additionalProperties": { "type": "string" }
            },

            "annotations": {
              "type": "object",
              "description": "Subset of metadata.annotations relevant to BGSpec (extractor may omit noisy ones).",
              "additionalProperties": { "type": "string" }
            },

            "replicas": {
              "type": ["integer", "null"],
              "description": "Desired replica count. Applicable to Deployment, StatefulSet, ReplicaSet.",
              "minimum": 0
            },

            "image": {
              "type": ["string", "null"],
              "description": "Primary container image (first container). E.g. 'payments-api:1.4.2'."
            },

            "resources": {
              "type": ["object", "null"],
              "description": "Resource requests and limits for the primary container.",
              "additionalProperties": false,
              "properties": {
                "requests": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "cpu":    { "type": "string", "description": "e.g. '250m'" },
                    "memory": { "type": "string", "description": "e.g. '512Mi'" }
                  }
                },
                "limits": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "cpu":    { "type": "string", "description": "e.g. '1'" },
                    "memory": { "type": "string", "description": "e.g. '1Gi'" }
                  }
                }
              }
            },

            "serviceType": {
              "type": ["string", "null"],
              "description": "For k8s kind=Service: ClusterIP, NodePort, LoadBalancer, or ExternalName.",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName", null]
            },

            "ports": {
              "type": ["array", "null"],
              "description": "Exposed ports. Applies to Service, Ingress, Pod.",
              "items": {
                "type": "object",
                "required": ["port"],
                "additionalProperties": false,
                "properties": {
                  "name":       { "type": "string" },
                  "port":       { "type": "integer", "minimum": 1, "maximum": 65535 },
                  "targetPort": { "type": ["integer", "string", "null"] },
                  "protocol":   { "type": "string", "enum": ["TCP", "UDP", "SCTP"], "default": "TCP" }
                }
              }
            },

            "storageClass": {
              "type": ["string", "null"],
              "description": "For PVC/PV nodes: storage class name."
            },

            "storageCapacity": {
              "type": ["string", "null"],
              "description": "For PVC/PV nodes: requested or provisioned capacity. E.g. '20Gi'."
            },

            "schedule": {
              "type": ["string", "null"],
              "description": "For CronJob nodes: cron expression. E.g. '0 * * * *'."
            }
          }
        },

        "parent": {
          "type": ["string", "null"],
          "description": "References another Floor 0 node's 'id'. Used for Cytoscape compound nodes (grouping). Typical use: a Workload node has parent pointing to a Namespace node. Null if this node is a top-level element."
        },

        "drillTo": {
          "type": ["string", "null"],
          "description": "Reserved for cross-floor navigation. At Floor 0 this is always null; populated by Floor 1+ references back to this node."
        },

        "meta": {
          "type": "object",
          "description": "Operational metadata. Populated by extractors and optionally enriched by humans. Not used for rendering.",
          "additionalProperties": false,
          "properties": {
            "description": {
              "type": "string",
              "description": "Free-text human description of this node's purpose."
            },
            "team": {
              "type": "string",
              "description": "Owning team name or identifier."
            },
            "repo": {
              "type": "string",
              "description": "Source repository URL or slug.",
              "format": "uri"
            },
            "docs": {
              "type": "string",
              "description": "Link to documentation.",
              "format": "uri"
            },
            "tags": {
              "type": "object",
              "description": "Arbitrary string key/value tags for search, filtering, and extractor hints (e.g. k8s.edge.* keys resolved by the edge mapper).",
              "additionalProperties": { "type": "string" }
            },
            "extractedAt": {
              "type": "string",
              "format": "date-time",
              "description": "ISO 8601 timestamp of when this node was last extracted from its source."
            },
            "extractorVersion": {
              "type": "string",
              "description": "Version of the BGSpec extractor that produced this node. E.g. '0.3.1'."
            }
          }
        }

      },

      "if": {
        "properties": { "infraProvider": { "const": "kubernetes" } }
      },
      "then": {
        "required": ["k8s"]
      }
    }
  },

  "examples": [
    {
      "data": {
        "id": "k8s-payments-api-deployment",
        "label": "Payments API",
        "floor": 0,
        "bgKind": "Workload",
        "infraProvider": "kubernetes",
        "k8s": {
          "kind": "Deployment",
          "name": "payments-api",
          "namespace": "payments",
          "apiVersion": "apps/v1",
          "replicas": 3,
          "image": "payments-api:2.1.0",
          "resources": {
            "requests": { "cpu": "250m", "memory": "512Mi" },
            "limits":   { "cpu": "1 ",    "memory": "1Gi"   }
          }
        },
        "parent": "k8s-payments-namespace",
        "drillTo": null,
        "meta": {
          "team": "payments-squad",
          "tags": {
            "environment": "production",
            "cost-center": "payments"
          },
          "criticality": "critical",
          "extractedAt": "2025-05-09T10:00:00Z",
          "extractorVersion": "0.1.0"
        }
      }
    },
    {
      "data": {
        "id": "k8s-payments-postgres-statefulset",
        "label": "Payments DB",
        "floor": 0,
        "bgKind": "Database",
        "infraProvider": "kubernetes",
        "k8s": {
          "kind": "StatefulSet",
          "name": "payments-postgres",
          "namespace": "payments",
          "apiVersion": "apps/v1",
          "replicas": 1,
          "image": "postgres:15.3"
        },
        "parent": "k8s-payments-namespace",
        "drillTo": null,
        "meta": {
          "criticality": "critical",
          "extractedAt": "2025-05-09T10:00:00Z",
          "extractorVersion": "0.1.0"
        }
      }
    },
    {
      "data": {
        "id": "k8s-payments-namespace",
        "label": "payments",
        "floor": 0,
        "bgKind": "Namespace",
        "infraProvider": "kubernetes",
        "k8s": {
          "kind": "Namespace",
          "name": "payments",
          "namespace": null,
          "apiVersion": "v1"
        },
        "parent": null,
        "drillTo": null,
        "meta": {
          "team": "platform-engineering",
          "extractedAt": "2025-05-09T10:00:00Z",
          "extractorVersion": "0.1.0"
        }
      }
    }
  ]
}